            <a href="#bookingForm" class="block text-center bg-blue-600 hover:bg-blue-700 text-white font-medium px-6 py-3 rounded-lg transition duration-300">
              Book Now
            </a>
          </div>
        </div>

        <!-- Sunset Package -->
        <div class="bg-neutral-800 rounded-lg overflow-hidden shadow-xl transition-transform duration-300 hover:transform hover:scale-105 animate__animated animate__fadeInUp animate__delay-1s">
          <div class="relative h-48">
            <img src="https://secretrouteskayaking.com/assets/images/intro/kochi.jpg" alt="Sunset Kayaking" class="w-full h-full object-cover">
          </div>
          <div class="p-6">
            <h3 class="text-xl font-bold text-white mb-2">Sunset Kayaking Tour</h3>
