  <script>
    document.addEventListener('DOMContentLoaded', function() {
      new Swiper('.swiper-container', {
        slidesPerView: 1,
        spaceBetween: 30,
        loop: true,
        autoplay: {
          delay: 5000,
          disableOnInteraction: false,
        },
        navigation: {
          nextEl: '.testimonial-next',
          prevEl: '.testimonial-prev',
        },
        breakpoints: {
          640: {
            slidesPerView: 2,
          },
          1024: {
            slidesPerView: 3,
          },
        },
      });
    });
  </script>
</div>
</htmlCode><htmlCode>
<div id="root">
  <section id="bookingForm" class="py-20 bg-neutral-100">
    <div class="max-w-4xl mx-auto px-4 sm:px-6 lg:px-8">
      <div class="text-center mb-16 animate__animated animate__fadeIn">
        <h2 class="text-3xl md:text-4xl font-bold text-neutral-900 mb-4">
          Book Your Kayaking Adventure
        </h2>
        <p class="text-neutral-600 text-lg">Reserve your spot for an unforgettable experience</p>
        <div class="w-24 h-1 bg-blue-600 mx-auto mt-4"></div>
      </div>

      <form id="kayakingBookingForm" class="bg-white rounded-lg shadow-xl p-8 animate__animated animate__fadeInUp">
        <div class="grid grid-cols-1 md:grid-cols-2 gap-6">
          <!-- Full Name -->
          <div class="col-span-2 md:col-span-1">
            <label for="fullName" class="block text-neutral-700 font-medium mb-2">Full Name *</label>
            <input type="text" id="fullName" name="fullName" required
              class="w-full px-4 py-3 rounded-lg border border-neutral-300 focus:border-blue-500 focus:ring-2 focus:ring-blue-200 transition duration-200"
              placeholder="Enter your full name">
          </div>

          <!-- WhatsApp Number -->
          <div class="col-span-2 md:col-span-1">
            <label for="whatsapp" class="block text-neutral-700 font-medium mb-2">WhatsApp Number *</label>
            <input type="tel" id="whatsapp" name="whatsapp" required
              class="w-full px-4 py-3 rounded-lg border border-neutral-300 focus:border-blue-500 focus:ring-2 focus:ring-blue-200 transition duration-200"
              placeholder="Enter your WhatsApp number">
          </div>

          <!-- Email -->
          <div class="col-span-2">
            <label for="email" class="block text-neutral-700 font-medium mb-2">Email Address *</label>
            <input type="email" id="email" name="email" required
              class="w-full px-4 py-3 rounded-lg border border-neutral-300 focus:border-blue-500 focus:ring-2 focus:ring-blue-200 transition duration-200"
              placeholder="Enter your email address">
          </div>

          <!-- Travel Date -->
          <div class="col-span-2 md:col-span-1">
            <label for="travelDate" class="block text-neutral-700 font-medium mb-2">Date of Travel *</label>
            <input type="date" id="travelDate" name="travelDate" required
              class="w-full px-4 py-3 rounded-lg border border-neutral-300 focus:border-blue-500 focus:ring-2 focus:ring-blue-200 transition duration-200">
          </div>

          <!-- Number of People -->
          <div class="col-span-2 md:col-span-1">
            <label for="people" class="block text-neutral-700 font-medium mb-2">Number of People *</label>
            <select id="people" name="people" required
              class="w-full px-4 py-3 rounded-lg border border-neutral-300 focus:border-blue-500 focus:ring-2 focus:ring-blue-200 transition duration-200">
              <option value="">Select number of people</option>
              <option value="1">1 Person</option>
              <option value="2">2 People</option>
              <option value="3">3 People</option>
              <option value="4">4 People</option>
              <option value="5">5+ People</option>
            </select>
          </div>

          <!-- Message -->
          <div class="col-span-2">
            <label for="message" class="block text-neutral-700 font-medium mb-2">Additional Message</label>
            <textarea id="message" name="message" rows="4"
              class="w-full px-4 py-3 rounded-lg border border-neutral-300 focus:border-blue-500 focus:ring-2 focus:ring-blue-200 transition duration-200"
              placeholder="Any special requests or questions?"></textarea>
          </div>

          <!-- Submit Button -->
          <div class="col-span-2">
            <button type="submit"
              class="w-full bg-blue-600 hover:bg-blue-700 text-white font-medium py-3 rounded-lg transition duration-300 transform hover:scale-[1.02]">
              Book Now
            </button>
          </div>
        </div>
      </form>
    </div>
  </section>

  <script>
    document.getElementById('kayakingBookingForm').addEventListener('submit', function(e) {
      e.preventDefault();
      
      // Basic form validation
      const required = ['fullName', 'whatsapp', 'email', 'travelDate', 'people'];
      let isValid = true;
      
      required.forEach(field => {
        const element = document.getElementById(field);
        if (!element.value) {
          element.classList.add('border-red-500');
          isValid = false;
        } else {
          element.classList.remove('border-red-500');
        }
      });

      if (!isValid) {
        alert('Please fill in all required fields');
        return;
      }

      // Here you would typically send the form data to your server
      alert('Thank you for your booking request! We will contact you shortly.');
      this.reset();
    });

    // Date input minimum date setting
    const dateInput = document.getElementById('travelDate');
    const tomorrow = new Date();
    tomorrow.setDate(tomorrow.getDate() + 1);
    dateInput.min = tomorrow.toISOString().split('T')[0];
  </script>
</div>
</htmlCode><htmlCode>
